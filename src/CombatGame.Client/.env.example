# Appwrite — project credentials are in src/lib/appwrite.ts
# Only the function ID is required for full game backend:
VITE_APPWRITE_FUNCTION_ID=
VITE_APPWRITE_DATABASE_ID=combat
VITE_APPWRITE_GAMES_COLLECTION_ID=games

# GitHub Pages base path
VITE_BASE_PATH=/hex-brigade-combat/

# Local SignalR fallback (when VITE_APPWRITE_FUNCTION_ID is empty)
# VITE_HUB_URL=http://localhost:5280/hub/game
